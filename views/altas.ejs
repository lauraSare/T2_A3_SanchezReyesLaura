<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <title>Agregar Alumno</title>
</head>
<body>
    <div class="container mt-5">
        <h2 class="text-danger text-center">Alta de Alumno</h2>
        <a href="/" class="btn btn-secondary mb-3">← Regresar</a>
        <div class="card p-4">
            <div class="mb-3">
                <label>Numero de Control:</label>
                <input type="text" id="numControl" class="form-control" />
            </div>
            <div class="mb-3">
                <label>Nombre:</label>
                <input type="text" id="nombre" class="form-control" />
            </div>
            <div class="mb-3">
                <label>Primer Apellido:</label>
                <input type="text" id="primerAp" class="form-control" />
            </div>
            <div class="mb-3">
                <label>Segundo Apellido:</label>
                <input type="text" id="segundoAp" class="form-control" />
            </div>
            <div class="mb-3">
                <label>Fecha de Nacimiento:</label>
                <input type="text" id="fechaNac" class="form-control" />
            </div>
            <div class="mb-3">
                <label>Semestre:</label>
                <input type="number" id="semestre" class="form-control" />
            </div>
            <div class="mb-3">
                <label>Carrera:</label>
                <input type="text" id="carrera" class="form-control" />
            </div>
            <button class="btn btn-primary" onclick="guardar()">Guardar</button>
        </div>
    </div>
    <script>
        function guardar() {
            const jsonData = {
                numControl: document.getElementById('numControl').value,
                nombre:     document.getElementById('nombre').value,
                primerAp:   document.getElementById('primerAp').value,
                segundoAp:  document.getElementById('segundoAp').value,
                fechaNac:   document.getElementById('fechaNac').value,
                semestre:   document.getElementById('semestre').value,
                carrera:    document.getElementById('carrera').value
            };
            fetch('/alumnos', {
                method: 'POST',
                body: JSON.stringify(jsonData),
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(() => window.location.href = '/');
        }
    </script>
</body>
</html>